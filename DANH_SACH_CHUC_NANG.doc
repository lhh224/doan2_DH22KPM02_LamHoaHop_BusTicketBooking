<h2>III. Bảng Thống Kê Chức Năng</h2>
<table>
    <tr>
        <th>Đối tượng</th>
        <th>Số nhóm chức năng (F1)</th>
        <th>Số chức năng chi tiết (F2)</th>
    </tr>
    <tr>
        <td>Khách vãng lai (Guest)</td>
        <td class="center">5</td>
        <td class="center">14</td>
    </tr>
    <tr>
        <td>Khách hàng (Customer)</td>
        <td class="center">5</td>
        <td class="center">18</td>
    </tr>
    <tr>
        <td>Admin / Nhà xe</td>
        <td class="center">10</td>
        <td class="center">33</td>
    </tr>
    <tr>
        <td class="bold">Tổng cộng</td>
        <td class="center bold">20</td>
        <td class="center bold">65</td>
    </tr>
</table>

