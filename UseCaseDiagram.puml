@startuml
left to right direction
skinparam packageStyle rectangle

actor "Khách vãng lai\n(Guest)" as Guest
actor "Khách hàng\n(Customer)" as Customer
actor "Quản trị viên\n(Admin)" as Admin

Customer -|> Guest
Admin -|> Customer

rectangle "Hệ Thống Đặt Vé Xe Khách Trực Tuyến" {
    
    ' Use cases for Guest
    usecase "UC01: Tìm kiếm chuyến xe" as UC01
    usecase "UC02: Xem chi tiết chuyến xe" as UC02
    usecase "UC03: Xem sơ đồ ghế theo chặng" as UC03
    usecase "UC04: Theo dõi hành trình chuyến xe" as UC04
    usecase "UC05: Chat với trợ lý AI" as UC05

    ' Use cases for Customer
    usecase "UC06: Đăng ký tài khoản" as UC06
    usecase "UC07: Đăng nhập / Đăng xuất" as UC07
    usecase "UC08: Đặt vé (chọn + khóa ghế)" as UC08
    usecase "UC09: Thanh toán qua QR" as UC09
    usecase "UC10: Xem thông tin vé điện tử" as UC10
    usecase "UC11: Xem lịch sử đặt vé" as UC11
    usecase "UC12: Hủy đặt vé" as UC12
    usecase "UC13: Đánh giá chuyến đi" as UC13
    usecase "UC14: Quản lý thông tin cá nhân" as UC14
    usecase "UC15: Xem thông báo" as UC15

    ' Use cases for Admin
    usecase "UC16: Quản lý chuyến xe" as UC16
    usecase "UC17: Quản lý tuyến đường" as UC17
    usecase "UC18: Quản lý nhà xe" as UC18
    usecase "UC19: Quản lý điểm dừng" as UC19
    usecase "UC20: Quản lý đặt vé" as UC20
    usecase "UC21: Dashboard thống kê doanh thu" as UC21
    usecase "UC22: Quản lý đánh giá" as UC22
    usecase "UC23: Quản lý tài khoản" as UC23
    usecase "UC24: Xem nhật ký hệ thống" as UC24
}

' Connections for Guest
Guest --> UC01
Guest --> UC02
Guest --> UC03
Guest --> UC04
Guest --> UC05

' Connections for Customer (Customer inherits Guest's Use Cases)
Customer --> UC06
Customer --> UC07
Customer --> UC08
Customer --> UC09
Customer --> UC10
Customer --> UC11
Customer --> UC12
Customer --> UC13
Customer --> UC14
Customer --> UC15

' Connections for Admin (Admin inherits Customer's Use cases)
Admin --> UC16
Admin --> UC17
Admin --> UC18
Admin --> UC19
Admin --> UC20
Admin --> UC21
Admin --> UC22
Admin --> UC23
Admin --> UC24

@enduml
